generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hashed
  name      String
  role      AdminRole @default(ADMIN)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLogin DateTime?

  @@index([email])
}

model Device {
  id          String              @id @default(cuid())
  deviceId    String              @unique
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  sessions    AttendanceSession[]
  logs        AttendanceLog[]
  auditLogs   AuditLog[]
}

model AttendanceSession {
  id         String        @id @default(cuid())
  deviceRef  String
  device     Device        @relation(fields: [deviceRef], references: [id], onDelete: Cascade)
  checkInAt  DateTime
  checkOutAt DateTime?
  checkInIp  String
  checkOutIp String?
  checkInUserAgent String?
  checkOutUserAgent String?
  status     SessionStatus @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([deviceRef, status])
  @@index([checkInAt, checkOutAt])
}

model AttendanceLog {
  id            String         @id @default(cuid())
  deviceId      String
  deviceRef     String?
  device        Device?        @relation(fields: [deviceRef], references: [id], onDelete: SetNull)
  action        AttendanceAction
  occurredAt    DateTime       @default(now())
  ip            String
  networkStatus NetworkStatus
  details       String?

  @@index([deviceId, occurredAt])
  @@index([ip, occurredAt])
}

model AuditLog {
  id              String         @id @default(cuid())
  deviceId        String
  deviceRef       String?
  device          Device?        @relation(fields: [deviceRef], references: [id], onDelete: SetNull)
  eventType       AuditEventType
  severity        AuditSeverity  @default(INFO)
  description     String
  ip              String
  userAgent       String?
  fingerprint     String?
  attemptCount    Int            @default(1)
  isBlocked       Boolean        @default(false)
  metadata        String?        // JSON field for additional data
  resolvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([deviceId, createdAt])
  @@index([eventType, severity])
  @@index([ip, createdAt])
  @@index([isBlocked, createdAt])
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
  ANALYST
}

enum SessionStatus {
  ACTIVE
  CLOSED
}

enum AttendanceAction {
  CHECK_IN
  CHECK_OUT
  STATUS
}

enum NetworkStatus {
  VALID
  SUSPICIOUS
}

enum AuditEventType {
  INVALID_IP
  DUPLICATE_REQUEST
  REPLAY_ATTEMPT
  BLOCKED_REQUEST
  ANOMALOUS_PATTERN
  RATE_LIMIT_EXCEEDED
  DEVICE_FINGERPRINT_MISMATCH
  UNUSUAL_TIME
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}
